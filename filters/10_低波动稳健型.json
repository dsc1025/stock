{
  "name": "低波动稳健型 — 放量上涨→放量下跌→缩量企稳",
  "filters": {
    "turnover": {"min": 0.1, "max": 4.0, "enabled": true},
    "amplitude": {"min": 0.1, "max": 8.0, "enabled": true},
    "pct_change": {"min": -10.0, "max": 10.0, "enabled": false},
    "price_range": {"min": 5, "max": 500, "enabled": true},
    "volume_rate": {"enabled": true, "min_vs_avg": 0.1, "max_vs_avg": 1.0, "days": 5, "desc": "当前缩量——成交量≤5日均量"},
    "prior_rally": {
      "enabled": true,
      "min_gain_pct": 20.0,
      "exclude_recent_days": 10,
      "desc": "回看期内曾大涨≥20%(回看天数由界面设定)"
    },
    "volume_selloff": {
      "enabled": true,
      "min_volume_ratio": 1.2,
      "min_drawdown_pct": 5.0,
      "desc": "峰值后出现放量(>1.2×均量)下跌, 回撤≥5%"
    },
    "volume_surge_history": {
      "enabled": false,
      "lookback_start": 5,
      "lookback_end": 20,
      "surge_volume_ratio": 1.5,
      "surge_min_pct": 3.0,
      "price_up": true,
      "desc": "5~20日内曾放量(>1.5倍均量)且累计涨幅≥3%"
    },
    "pullback_from_high": {
      "enabled": false,
      "max_pullback_pct": 8.0,
      "lookback_days": 20,
      "desc": "从近期高点最大回撤≤8%"
    },
    "rsi": {"enabled": false, "min": 35, "max": 65},
    "rsi_oversold": {"enabled": false, "threshold": 30},
    "rsi_overbought": {"enabled": false, "threshold": 70},
    "macd_golden_cross": {"enabled": false},
    "macd_death_cross": {"enabled": false},
    "kdj": {"enabled": false, "min": 10, "max": 90},
    "kdj_low_cross": {"enabled": false, "threshold": 30},
    "bb_position": {"enabled": false, "position": "middle"},
    "ma_trend": {"enabled": false, "type": "bullish"},
    "price_vs_ma20": {"enabled": false, "relation": "above", "pct_min": 0.0, "pct_max": 10.0},
    "price_vs_ma60": {"enabled": false, "relation": "above", "pct": 0.0},
    "atr_ratio": {"enabled": false, "min": 0.0, "max": 2.0},
    "high_low_ratio": {"enabled": false, "min": 0.90}
  },
  "signal_weights": {
    "prior_rally": 1.5,
    "volume_selloff": 2.0,
    "volume": 0.5
  }
}
